# Project
PROJECT_NAME=Techstein RAG Portal
LOG_LEVEL=DEBUG

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=database
POSTGRES_HOST=host
POSTGRES_PORT=port

# Vector DB (Qdrant)
QDRANT_HOST=vector_db
QDRANT_PORT=6333

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI/LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_API_KEY=ollama
OPENAI_API_KEY=
GEMINI_API_KEY=
HUGGINGFACE_TOKEN=

# Embedding & Reranking
EMBEDDING_MODEL_ID=mixedbread-ai/mxbai-embed-large-v1
RERANKER_MODEL_ID=BAAI/bge-reranker-base

# RAG Parameters
K_RETRIEVAL=10
TOP_K=5
THRESHOLD=0.3

# System User
SYSTEM_USER_EMAIL=system@techstein.ai
SYSTEM_USER_PASSWORD=change-this-password